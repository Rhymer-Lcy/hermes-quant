# Copy this file to .env.local and fill in your secrets.
# .env.local is gitignored and must never be committed.
# Values are read from the real environment first, then from .env.local.

# Tushare Pro token — OPTIONAL.
# BaoStock (anonymous, no token) covers the historical daily backbone, so you do
# NOT need this to start. Register free at https://tushare.pro/register to get a
# token; note that daily-bar and some endpoints require accumulated credits.
TUSHARE_TOKEN=

# --- Network proxy (OPTIONAL) -------------------------------------------------------
# BaoStock/Tushare are domestic and normally need NO proxy — leave these unset unless
# your network requires one (a foreign-bound proxy can break domestic APIs). Standard
# names honored by requests/urllib; hermes.config exports them to the process
# environment at import (a value already set in the real environment always wins).
# HTTP_PROXY=http://127.0.0.1:10808
# HTTPS_PROXY=http://127.0.0.1:10808
# NO_PROXY=localhost,127.0.0.1
