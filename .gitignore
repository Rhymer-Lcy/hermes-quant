/results/
*.joblib
*.parquet

# editable-installed forks (kept as separate repos, not vendored)
external/*/

# python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# editors / os
.vscode/
.idea/
.DS_Store
Thumbs.db
