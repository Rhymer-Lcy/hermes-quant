# secrets — ignore every dotenv variant, keep only the committed template
.env
.env.*
!.env.template

# local data lake & caches (large, regenerable) — anchored to repo root so the
# `hermes/data/` source package is NOT ignored, only the top-level data lake.
# data/manual/ is the one tracked exception: small hand-compiled reference inputs
# (e.g. the symposium event list) that a study cannot regenerate from a vendor.
/data/*
!/data/manual/
/results/
*.joblib
*.parquet

# editable-installed forks (separate repos, not vendored). Ignore everything under
# external/ except the two tracked metadata files, so a loose file dropped there
# (scratch log, token note) is not silently staged by `git add external/`.
external/*
!external/README.md
!external/versions.lock

# notebooks: scratch — never commit cell outputs (data/secrets leak surface)
notebooks/*.ipynb

# python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# editors / os
.vscode/
.idea/
.DS_Store
Thumbs.db
